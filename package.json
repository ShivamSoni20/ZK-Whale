{
  "name": "zkwhale",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile-contract": "compact compile contracts/src/vibe-trader.compact contracts/managed/vibe-trader.compact",
    "proof-server:up": "docker run -d -p 6300:6300 midnightntwrk/proof-server:8.0.3 midnight-proof-server -v",
    "proof-server:down": "docker stop $(docker ps -q --filter ancestor=midnightntwrk/proof-server:8.0.3)",
    "deploy:preprod": "npx ts-node src/deploy.ts",
    "deploy:preview": "npx ts-node src/deploy.ts --network preview",
    "cli": "npx ts-node src/cli.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "^0.15.0",
    "@midnight-ntwrk/midnight-js-contracts": "^4.0.4",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "^4.0.4",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "^4.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^16.0.0",
    "effect": "^3.21.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "14.2.0",
    "openai": "^4.0.0",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.0",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
